{
  "manifest_version": 3,
  "name": "AI Dev Console Panel",
  "version": "0.3.0",
  "description": "Chrome Manifest V3 AI 调试侧边栏，支持日志采集、请求追踪、域名白名单和 AI 分析。",
  "action": {
    "default_title": "打开 AI Dev Console Panel",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.haoyl2025.cn/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "js": [
        "content/page-hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
